{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "diagnostics": {
    "libraryFiles": "Disable"
  },
  "runtime": {
    "version": "Lua 5.1",
    "path": [
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "workspace": {
    "checkThirdParty": "Disable",
    "library": [
      "$VIMRUNTIME",
      "$PWD/.dependencies/plenary.nvim",
      "$PWD/.dependencies/nui.nvim",
      "$PWD/.dependencies/nvim-web-devicons",
      "$PWD/.dependencies/image.nvim",
      "$PWD/.dependencies/snacks.nvim",
      "$PWD/.dependencies/nvim-window-picker",
      "$PWD/.dependencies/nvim-treesitter"
    ],
    "ignoreDir": [
      ".dependencies",
      ".luarocks",
      ".lua",
      ".repro",
      "tests"
    ]
  }
}
